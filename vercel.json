{
  "headers": [
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/_next/image(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(favicon.ico|logo.svg|logo-footer.svg|iRise-Logo-White.png|pc-partners.png|precondo_main_image.webp|splashscreen.jpg)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, s-maxage=31536000, stale-while-revalidate=43200"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/r/_next/(.*)",
      "destination": "/_next/$1"
    }
  ],
  "redirects": [
    {
      "source": "/locations/(.*)",
      "destination": "/r/locations/$1",
      "permanent": true
    },
    {
      "source": "/listing/(.*)",
      "destination": "/r/listing/$1",
      "permanent": true
    },
    {
      "source": "/building/(.*)",
      "destination": "/r/building/$1",
      "permanent": true
    },
    {
      "source": "/search/(.*)",
      "destination": "/r/search/$1",
      "permanent": true
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}