{
  "headers": [
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/_next/image(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(favicon.ico|logo.svg|logo-footer.svg|iRise-Logo-White.png|pc-partners.png|precondo_main_image.webp|splashscreen.jpg)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, s-maxage=31536000, stale-while-revalidate=43200"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/r/_next/(.*)",
      "destination": "/_next/$1"
    },
    {
      "source": "/r/(.*)",
      "destination": "/$1"
    },
    {
      "source": "/favicon.ico",
      "destination": "/favicon.ico"
    },
    {
      "source": "/logo.svg",
      "destination": "/logo.svg"
    },
    {
      "source": "/logo-footer.svg",
      "destination": "/logo-footer.svg"
    },
    {
      "source": "/pc-partners.png",
      "destination": "/pc-partners.png"
    },
    {
      "source": "/precondo_main_image.webp",
      "destination": "/precondo_main_image.webp"
    },
    {
      "source": "/splashscreen.jpg",
      "destination": "/splashscreen.jpg"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}